        <mxCell id="OzgN8v3V9l0M2NgUhT2L-25" connectable="0" parent="OzgN8v3V9l0M2NgUhT2L-24" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" value="send event" vertex="1">
