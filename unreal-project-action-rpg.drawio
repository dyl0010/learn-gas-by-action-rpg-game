        </mxCell>
        <mxCell id="OzgN8v3V9l0M2NgUhT2L-23" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;autosize=1;resizable=0;fontSize=32;" value="Tags在其中的角色" vertex="1">
